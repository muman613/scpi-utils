<!DOCTYPE node PUBLIC
  "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
  "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">

<node name="/org/scpi">
  <interface name="org.scpi.Registry">
    <method name="ListDevices">
      <arg name="devices" type="a(ssa{sv})" direction="out"/>
    </method>

    <method name="GetDevice">
      <arg name="name" type="s" direction="in"/>
      <arg name="device" type="(ssa{sv})" direction="out"/>
    </method>

    <method name="AddOrUpdateDevice">
      <arg name="name" type="s" direction="in"/>
      <arg name="port" type="s" direction="in"/>
      <arg name="options" type="a{sv}" direction="in"/>
    </method>

    <method name="RemoveDevice">
      <arg name="name" type="s" direction="in"/>
      <arg name="removed" type="b" direction="out"/>
    </method>

    <method name="ScanSerialDevices">
      <arg name="results" type="a(ssba{sv})" direction="out"/>
    </method>

    <signal name="RegistryChanged"/>

    <signal name="DeviceAdded">
      <arg name="name" type="s"/>
    </signal>

    <signal name="DeviceUpdated">
      <arg name="name" type="s"/>
    </signal>

    <signal name="DeviceRemoved">
      <arg name="name" type="s"/>
    </signal>
  </interface>

  <interface name="org.scpi.DeviceControl">
    <method name="Open">
      <arg name="name" type="s" direction="in"/>
    </method>

    <method name="Close">
      <arg name="name" type="s" direction="in"/>
    </method>

    <method name="IsOpen">
      <arg name="name" type="s" direction="in"/>
      <arg name="open" type="b" direction="out"/>
    </method>

    <method name="QueryIdentity">
      <arg name="name" type="s" direction="in"/>
      <arg name="identity" type="s" direction="out"/>
    </method>

    <method name="WriteCommand">
      <arg name="name" type="s" direction="in"/>
      <arg name="command" type="s" direction="in"/>
    </method>

    <method name="Query">
      <arg name="name" type="s" direction="in"/>
      <arg name="command" type="s" direction="in"/>
      <arg name="response" type="s" direction="out"/>
    </method>

    <method name="Reset">
      <arg name="name" type="s" direction="in"/>
    </method>

    <method name="ClearStatus">
      <arg name="name" type="s" direction="in"/>
    </method>

    <method name="ConfigureDvm">
      <arg name="name" type="s" direction="in"/>
      <arg name="function" type="s" direction="in"/>
      <arg name="range" type="s" direction="in"/>
    </method>

    <method name="SetDisplay">
      <arg name="name" type="s" direction="in"/>
      <arg name="display" type="s" direction="in"/>
      <arg name="function" type="s" direction="in"/>
    </method>

    <method name="ReadDisplay">
      <arg name="name" type="s" direction="in"/>
      <arg name="display" type="s" direction="in"/>
      <arg name="value" type="s" direction="out"/>
    </method>

    <method name="ReadDisplays">
      <arg name="name" type="s" direction="in"/>
      <arg name="value" type="s" direction="out"/>
    </method>

    <signal name="DeviceStateChanged">
      <arg name="name" type="s"/>
      <arg name="state" type="s"/>
    </signal>

    <signal name="DeviceError">
      <arg name="name" type="s"/>
      <arg name="message" type="s"/>
    </signal>
  </interface>
</node>
